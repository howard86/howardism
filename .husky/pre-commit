bun x lint-staged

# 1. Local secret scanner (gitleaks)
if command -v gitleaks >/dev/null 2>&1; then
  gitleaks protect --staged --redact --no-banner
else
  echo "warning: gitleaks not installed; skipping local secret scan. Install with: brew install gitleaks" >&2
fi

# 2. Local spellcheck (typos)
if command -v typos >/dev/null 2>&1; then
  typos
else
  echo "warning: typos not installed; skipping local spell-check. Install with: brew install typos-cli" >&2
fi

# 3. Local actions checker (actionlint)
if command -v actionlint >/dev/null 2>&1; then
  actionlint
else
  echo "warning: actionlint not installed; skipping local workflow linting. Install with: brew install actionlint" >&2
fi
