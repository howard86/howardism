{
  "$schema": "https://biomejs.dev/schemas/2.4.10/schema.json",
  "extends": [
    "ultracite/biome/core",
    "ultracite/biome/next",
    "ultracite/biome/react"
  ],
  "files": {
    "includes": ["!!.husky"]
  },
  "javascript": {
    "globals": [
      "describe",
      "it",
      "test",
      "expect",
      "beforeAll",
      "beforeEach",
      "afterAll",
      "afterEach"
    ]
  },
  "overrides": [
    {
      "includes": ["**/test/**"],
      "linter": {
        "rules": {
          "style": {
            "useFilenamingConvention": "off"
          }
        }
      }
    }
  ]
}
