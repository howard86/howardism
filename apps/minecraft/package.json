{
  "name": "@howardism/minecraft",
  "version": "1.0.14",
  "private": true,
  "scripts": {
    "check-all": "bun run type-check && bun run lint && bun run format",
    "dev": "next dev",
    "debug": "NODE_OPTIONS='--inspect' next dev",
    "analyze": "ANALYZE=true next build",
    "clean": "rm -rf .next node_modules",
    "build": "next build",
    "start": "next start",
    "type-check": "tsc --pretty --noEmit",
    "format": "ultracite fix",
