{
  "extends": "@howardism/tsconfig/nextjs",
  "compilerOptions": {
    "moduleResolution": "bundler",
    "paths": {
      "@/*": ["./src/*"],
      "@/lib/*": ["./src/lib/*", "../../packages/ui/src/lib/*"],
      "@/components/*": [
        "./src/components/*",
        "../../packages/ui/src/components/*"
      ],
      "@howardism/ui/components/*": ["../../packages/ui/src/components/*"],
      "@howardism/ui/lib/*": ["../../packages/ui/src/lib/*"],
      "@howardism/ui/styles/*": ["../../packages/ui/src/styles/*"]
    },
    "plugins": [
      {
        "name": "next"
      }
    ],
    "types": ["bun"]
  },
  "ts-node": {
    "compilerOptions": {
      "module": "CommonJS"
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
