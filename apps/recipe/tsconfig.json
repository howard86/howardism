{
  "extends": "@howardism/tsconfig/nextjs",
  "compilerOptions": {
    "baseUrl": ".",
    "moduleResolution": "bundler",
    "paths": {
      "@/*": ["src/*"],
      "@/lib/*": ["src/lib/*", "../../packages/ui/src/lib/*"],
      "@/components/*": [
        "src/components/*",
        "../../packages/ui/src/components/*"
      ],
      "@howardism/ui/components/*": ["../../packages/ui/src/components/*"],
      "@howardism/ui/lib/*": ["../../packages/ui/src/lib/*"]
    },
    "incremental": true,
    "strictNullChecks": true
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx"],
  "exclude": ["node_modules"]
}
