{
  "name": "@howardism/template",
  "version": "0.1.11",
  "private": true,
  "scripts": {
    "check-all": "bun run type-check && bun run lint && bun run format",
    "dev": "next dev",
    "debug": "NODE_OPTIONS='--inspect' next dev",
    "analyze": "ANALYZE=true next build",
    "clean": "rm -rf .next node_modules",
    "build": "next build",
    "start": "next start",
    "type-check": "tsc --pretty --noEmit",
    "format": "ultracite fix",
    "lint": "ultracite check",
    "test": "bun test",
    "test-all": "bun run lint && bun run type-check && bun run test"
  },
  "dependencies": {
    "next": "^16.2.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@types/react": "^19.2.14"
  }
}
