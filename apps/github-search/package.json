{
  "name": "@howardism/github-search",
  "version": "1.0.14",
  "private": true,
  "scripts": {
    "check-all": "bun run type-check && bun run lint && bun run format",
    "type-check": "tsc --noEmit",
    "lint": "ultracite check",
    "format": "ultracite fix",
    "dev": "next dev",
    "debug": "NODE_OPTIONS='--inspect' next dev",
    "analyze": "ANALYZE=true next build",
    "clean": "rm -rf .next node_modules",
    "build": "next build",
    "start": "next start",
    "test": "bun test",
    "codegen": "graphql-codegen --config codegen.yml"
  },
  "dependencies": {
    "@apollo/client": "^4.1.6",
    "@howardism/components-common": "workspace:*",
    "@howardism/security-headers": "workspace:*",
    "@howardism/ui": "workspace:*",
    "graphql": "^16.8.1",
    "graphql-tag": "^2.12.6",
    "lucide-react": "^1.7.0",
    "next": "^16.2.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@babel/core": "^7.23.9",
    "@tailwindcss/postcss": "^4.0.0",
    "tailwindcss": "^4.0.0",
    "@graphql-codegen/add": "^6.0.0",
    "@graphql-codegen/cli": "6.2.1",
    "@graphql-codegen/introspection": "5.0.1",
    "@graphql-codegen/typescript": "5.0.9",
    "@graphql-codegen/typescript-operations": "^5.0.9",
    "@graphql-codegen/typescript-react-apollo": "^4.3.0",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2"
  }
}
