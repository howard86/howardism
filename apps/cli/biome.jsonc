{
  "root": false,
  // The repo-root config parks the rules newly enabled by ultracite 7.9.4.
  // It extends last so those overrides win over the presets above.
  "extends": ["ultracite/biome/core", "../../biome.json"],
  "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
  "javascript": {
    "globals": ["Bun"]
  }
}
