{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "include": [
    "files",
    "dependencies",
    "devDependencies",
    "optionalPeerDependencies",
    "unlisted",
    "binaries",
    "unresolved"
  ],
  "ignoreDependencies": [
    "@biomejs/biome",
    "@semantic-release/github",
    "@semantic-release/npm"
  ],
  "ignoreUnresolved": ["^next$"],
  "workspaces": {
    ".": {
      "commitlint": true
    },
    "apps/blog": {
      "entry": ["src/lib/rehype-mdx-headings.mjs", "scripts/migrate-mdx.ts"],
      "ignore": ["src/content/**"]
    },
    "apps/cli": {},
    "packages/*": {}
  }
}
