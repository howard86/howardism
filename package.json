{
  "name": "howardism",
  "scripts": {
    "clean": "bun run clean:packages && bun run clean:root",
    "clean:root": "rm -rf node_modules",
    "clean:packages": "turbo run clean",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "lint:root": "ultracite check",
    "format": "ultracite fix",
    "type-check": "turbo run type-check",
    "typecheck": "turbo run type-check",
    "test": "turbo run test",
    "prepare": "husky",
    "check": "ultracite check",
    "fix": "ultracite fix"
  },
  "version": "2.13.0",
  "workspaces": [
    "apps/**",
    "packages/**"
  ],
  "private": true,
  "repository": "https://github.com/howard86/howardism",
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@howardism/test-config": "workspace:*",
    "@howardism/tsconfig": "workspace:*",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.8",
    "@semantic-release/npm": "^13.1.5",
    "@testing-library/react": "^16.3.2",
    "@types/bun": "^1.3.14",
    "@types/node": "^25.8.0",
    "bun-types": "^1.3.14",
    "commitlint": "^21.0.0",
    "commitlint-config-gitmoji": "^2.3.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "semantic-release": "^25.0.3",
    "semantic-release-gitmoji": "^1.6.9",
    "turbo": "^2.9.14",
    "typescript": "^6.0.3",
    "ultracite": "7.8.3"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,jsonc,css,scss,md,mdx}": [
      "bun x ultracite fix"
    ]
  },
  "packageManager": "bun@1.3.11",
  "engines": {
    "node": ">=24"
  }
}
