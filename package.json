{
	"name": "howardism",
	"version": "1.0.24",
	"private": true,
	"repository": "https://github.com/howard86/howardism",
	"packageManager": "bun@1.3.11",
	"workspaces": [
		"apps/**",
		"packages/**"
	],
	"scripts": {
		"clean": "bun run clean:packages && bun run clean:root",
		"clean:root": "rm -rf node_modules",
		"clean:packages": "turbo run clean",
		"build": "turbo run build",
		"lint": "turbo run lint",
		"lint:root": "biome check .",
		"format": "biome check --write .",
		"type-check": "turbo run type-check",
		"test": "turbo run test",
		"prepare": "husky"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.10",
		"@changesets/changelog-github": "^0.6.0",
		"@changesets/cli": "^2.30.0",
		"@howardism/jest-config": "workspace:*",
		"@howardism/tsconfig": "workspace:*",
		"@next/bundle-analyzer": "^14.1.0",
		"@testing-library/react": "^14.2.1",
		"@types/jest": "^29.5.12",
		"@types/node": "^24.0.0",
		"commitlint": "^20.0.0",
		"commitlint-config-gitmoji": "^2.3.1",
		"husky": "^9.0.11",
		"jest": "^29.7.0",
		"react": "^18.2.0",
		"react-dom": "^18.2.0",
		"react-html-props": "^2.0.9",
		"turbo": "^2.9.4",
		"typescript": "^5.3.3",
		"ultracite": "^7.4.3"
	},
	"engines": {
		"node": ">=18"
	}
}
