{
  "name": "howardism",
  "scripts": {
    "clean": "bun run clean:packages && bun run clean:root",
    "clean:root": "rm -rf node_modules",
    "clean:packages": "turbo run clean",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "lint:root": "ultracite check",
    "format": "ultracite fix",
    "type-check": "turbo run type-check",
    "test": "turbo run test",
    "prepare": "husky",
    "check": "ultracite check",
    "fix": "ultracite fix"
  },
  "version": "1.0.24",
  "workspaces": [
    "apps/**",
    "packages/**"
  ],
  "private": true,
  "repository": "https://github.com/howard86/howardism",
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.30.0",
    "@howardism/test-config": "workspace:*",
    "@howardism/tsconfig": "workspace:*",
    "@next/bundle-analyzer": "^16.2.2",
    "@testing-library/react": "^16.3.2",
    "@types/bun": "^1.3.11",
    "@types/node": "^25.5.2",
    "bun-types": "^1.3.11",
    "commitlint": "^21.0.0",
    "commitlint-config-gitmoji": "^2.3.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-html-props": "^2.1.1",
    "turbo": "^2.9.5",
    "typescript": "^6.0.2",
    "ultracite": "7.7.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,jsonc,css,scss,md,mdx}": [
      "bun x ultracite fix"
    ]
  },
  "packageManager": "bun@1.3.11",
  "engines": {
    "node": ">=24"
  }
}
