{
  "name": "howardism",
  "version": "1.0.24",
  "private": true,
  "repository": "https://github.com/howard86/howardism",
  "packageManager": "bun@1.3.11",
  "workspaces": [
    "apps/**",
    "packages/**"
  ],
  "scripts": {
    "clean": "bun run clean:packages && bun run clean:root",
    "clean:root": "rm -rf node_modules",
    "clean:packages": "turbo run clean",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "lint:root": "TIMING=1 eslint .",
    "format": "prettier --write --list-different .",
    "type-check": "turbo run type-check",
    "test": "turbo run test",
    "prepare": "husky"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@howardism/jest-config": "workspace:*",
    "@howardism/tsconfig": "workspace:*",
    "@next/bundle-analyzer": "^14.1.0",
    "@next/eslint-plugin-next": "14",
    "@testing-library/react": "^14.2.1",
    "@types/jest": "^29.5.12",
    "@types/node": "^24.0.0",
    "@typescript-eslint/eslint-plugin": "7",
    "@typescript-eslint/parser": "7",
    "commitlint": "^20.0.0",
    "commitlint-config-gitmoji": "^2.3.1",
    "eslint": "^8.56.0",
    "eslint-config-airbnb": "^19.0.4",
    "eslint-config-airbnb-typescript": "^18.0.0",
    "eslint-config-howardism": "workspace:*",
    "eslint-config-next": "14",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-alias": "^1.1.2",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jest": "^29.15.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-testing-library": "^7.16.2",
    "husky": "^9.0.11",
    "jest": "^29.7.0",
    "lint-staged": "^15.2.2",
    "prettier": "^3.2.5",
    "prettier-plugin-tailwindcss": "^0.7.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-html-props": "^2.0.9",
    "turbo": "^2.9.4",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18"
  }
}
