{
  "extends": "@howardism/tsconfig/nextjs",
  "compilerOptions": {
    "strictNullChecks": true,
    "moduleResolution": "bundler",
    "baseUrl": ".",
    "paths": {
      "@/*": ["../../ui/src/*"],
      "@howardism/ui/components/*": ["../../ui/src/components/*"],
      "@howardism/ui/lib/*": ["../../ui/src/lib/*"]
    }
  },
  "include": ["src", "index.ts"],
  "exclude": ["node_modules"]
}
